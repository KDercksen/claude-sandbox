{
  "name": "claude-sandbox",
  "description": "A new CLI generated with oclif",
  "version": "0.0.0",
  "author": "KDercksen",
  "bin": {
    "claude-sandbox": "./bin/run.js"
  },
  "bugs": "https://github.com/tmp/claude-sandbox/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "dockerode": "^4.0.10",
    "tar-fs": "^3.1.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/dockerode": "^4.0.1",
    "@types/mocha": "^10",
    "@types/node": "^18.19.130",
    "@types/tar-fs": "^2.0.4",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./docker",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/tmp/claude-sandbox",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "claude-sandbox",
    "dirname": "claude-sandbox",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " "
  },
  "repository": "tmp/claude-sandbox",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
