#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="$HOME/.claude-sandbox"
CONFIG_FILE="$CONFIG_DIR/config.json"

# --- Utilities ---

die() { echo "error: $*" >&2; exit 1; }
warn() { echo "warning: $*" >&2; }

# --- Config ---

CONFIG_IMAGE="claude-sandbox:latest"
CONFIG_BRANCH_PREFIX="claude/"
CONFIG_GITHUB_PAT=""
CONFIG_ALLOWED_DOMAINS=""

load_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    CONFIG_IMAGE=$(jq -r '.image // "claude-sandbox:latest"' "$CONFIG_FILE")
    CONFIG_BRANCH_PREFIX=$(jq -r '.defaultBranchPrefix // "claude/"' "$CONFIG_FILE")
    CONFIG_GITHUB_PAT=$(jq -r '.githubPat // empty' "$CONFIG_FILE")
    CONFIG_ALLOWED_DOMAINS=$(jq -r '(.allowedDomains // []) | join(",")' "$CONFIG_FILE")
  fi
}

# --- GitHub Token ---

resolve_github_token() {
  if [[ -n "$CONFIG_GITHUB_PAT" ]]; then
    echo "$CONFIG_GITHUB_PAT"
    return
  fi
  local token
  token=$(gh auth token 2>/dev/null) || true
  token="${token%$'\n'}"
  if [[ -n "$token" ]]; then
    echo "$token"
    return
  fi
  die 'No GitHub token found. Set githubPat in config or run "gh auth login".'
}

# --- Container Names ---

sanitize_name() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g; s/-\+/-/g; s/^-//; s/-$//'
}

generate_container_name() {
  local repo="$1" name="${2:-}"
  if [[ -n "$name" ]]; then
    local sanitized
    sanitized=$(sanitize_name "$name")
    echo "claude-sandbox-${sanitized:-unnamed}"
  else
    local repo_name="${repo##*/}"
    local sanitized
    sanitized=$(sanitize_name "$repo_name")
    local suffix
    suffix=$(head -c3 /dev/urandom | xxd -p)
    echo "claude-sandbox-${sanitized:-sandbox}-$suffix"
  fi
}

# --- Docker Image ---

docker_dir_hash() {
  find "$SCRIPT_DIR/docker" -type f -print0 | sort -z | xargs -0 sha256sum | sha256sum | cut -d' ' -f1
}

ensure_image() {
  local tag="$CONFIG_IMAGE"
  local current_hash
  current_hash=$(docker_dir_hash)

  local image_hash
  image_hash=$(docker inspect -f '{{index .Config.Labels "claude-sandbox.build-hash"}}' "$tag" 2>/dev/null) || image_hash=""

  if [[ "$current_hash" == "$image_hash" ]]; then
    return
  fi

  if [[ -z "$image_hash" ]]; then
    echo "Image $tag not found, building..."
  else
    echo "Docker files changed, rebuilding $tag..."
  fi

  docker build -t "$tag" --label "claude-sandbox.build-hash=$current_hash" "$SCRIPT_DIR/docker"
  echo "Image $tag ready."
}

# --- Prompt Building ---

build_prompt() {
  local repo="$1" prompt="${2:-}" issue="${3:-}" pr="${4:-}" create_pr="${5:-false}"
  local parts=()

  if [[ -n "$prompt" ]]; then
    parts+=("$prompt")
  fi

  if [[ -n "$issue" ]]; then
    local data title body
    data=$(gh issue view "$issue" --repo "$repo" --json title,body) || die "Failed to fetch issue #$issue"
    title=$(echo "$data" | jq -r .title)
    body=$(echo "$data" | jq -r .body)
    parts+=($'\n---\n'"GitHub Issue #${issue}:"$'\n\n'"# ${title}"$'\n\n'"${body}")
  fi

  if [[ -n "$pr" ]]; then
    local data title body
    data=$(gh pr view "$pr" --repo "$repo" --json title,body) || die "Failed to fetch PR #$pr"
    title=$(echo "$data" | jq -r .title)
    body=$(echo "$data" | jq -r .body)
    parts+=($'\n---\n'"GitHub PR #${pr}:"$'\n\n'"# ${title}"$'\n\n'"${body}")
  fi

  if [[ ${#parts[@]} -eq 0 ]]; then
    die "Prompt required: provide at least one of --prompt, --issue, or --pr"
  fi

  # Default instruction if no explicit prompt
  if [[ -z "$prompt" ]]; then
    parts=("Resolve the following. Make the necessary code changes, ensure tests pass, and commit your work." "${parts[@]}")
  fi

  # Git workflow instructions
  local workflow
  workflow=$'\n---\n## Git workflow\n\n- Make small, focused commits as you go — one per logical change. Use descriptive commit messages.'
  if [[ "$create_pr" == "true" ]]; then
    workflow+=$'\n- When you are done, push your branch and create a PR with a clear title and description summarizing what changed and why.'
  else
    workflow+=$'\n- When you are done, commit your work. The branch will be pushed automatically.'
  fi
  parts+=("$workflow")

  # Progress update instructions
  local progress
  progress=$'\n---\n## Progress updates\n\nAs you work, append progress lines to /workspace/.claude-progress using these markers:\n\n@@PHASE("name") — emit when you transition to a new phase of work. Suggested phases:\n  exploring codebase, setting up environment, brainstorming design, writing tests,\n  implementing, debugging, reviewing, creating pr\n\n@@UPDATE("detail") — emit after each significant action. Include what you did,\n  what skill or approach you are using, and any subagents you spawned. Examples:\n    @@UPDATE("Using TDD — writing failing tests for auth module")\n    @@UPDATE("Spawned 3 subagents for parallel implementation")\n    @@UPDATE("All 8 tests passing, moving to integration tests")\n    @@UPDATE("Installing npm dependencies — found package.json with 12 deps")\n\n@@ARTIFACT("type: description") — emit when you produce a concrete output.\n  Types: commit, pr, file, test. Examples:\n    @@ARTIFACT("commit: Add failing tests for user authentication")\n    @@ARTIFACT("pr: https://github.com/org/repo/pull/42")\n    @@ARTIFACT("test: 8 passing, 0 failing")\n\nStart with @@PHASE("exploring codebase") as your first line. Update phases as your work evolves.'
  parts+=("$progress")

  local IFS=$'\n'
  printf '%s\n' "${parts[*]}"
}

# --- Spawn Container ---

spawn_container() {
  local repo="$1" prompt="${2:-}" issue="${3:-}" pr="${4:-}" create_pr="${5:-false}"
  local branch="${6:-}" name="${7:-}" extra_domains="${8:-}"

  local full_prompt
  full_prompt=$(build_prompt "$repo" "$prompt" "$issue" "$pr" "$create_pr")

  local container_name
  container_name=$(generate_container_name "$repo" "$name")

  # Resolve branch
  if [[ -z "$branch" && "$create_pr" == "true" ]]; then
    branch="${CONFIG_BRANCH_PREFIX}${container_name}"
  fi

  # Merge config allowed domains with extra domains
  local all_domains="$CONFIG_ALLOWED_DOMAINS"
  if [[ -n "$extra_domains" ]]; then
    if [[ -n "$all_domains" ]]; then
      all_domains="${all_domains},${extra_domains}"
    else
      all_domains="$extra_domains"
    fi
  fi

  local github_token
  github_token=$(resolve_github_token)

  # Build docker run args
  local -a docker_args=(
    run -d
    --name "$container_name"
    --label "app=claude-sandbox"
    --label "claude-sandbox.repo=$repo"
    --cap-add NET_ADMIN
    --cap-add NET_RAW
    -v "${HOME}/.claude:/home/claude/.claude.host:ro"
    -v "${HOME}/.claude.json:/home/claude/.claude.json.host:ro"
    -e "REPO=${repo}"
    -e "PROMPT=${full_prompt}"
    -e "GITHUB_TOKEN=${github_token}"
    -e "CREATE_PR=${create_pr}"
  )

  if [[ -n "$branch" ]]; then
    docker_args+=(-e "BRANCH=${branch}")
  fi

  if [[ -n "$all_domains" ]]; then
    docker_args+=(-e "EXTRA_ALLOWED_DOMAINS=${all_domains}")
  fi

  docker_args+=("$CONFIG_IMAGE")

  docker "${docker_args[@]}" >/dev/null || die "Failed to start container $container_name"

  # Return info as tab-separated values
  printf '%s\t%s\t%s\n' "$container_name" "$repo" "$branch"
}

# --- Commands ---

build_monitor_prompt() {
  local container_name="$1" repo="$2"
  cat <<MONITOR
Monitor the Docker container "${container_name}" (repo: ${repo}).

Your job:
1. Every 10 seconds, check for progress updates by running:
   docker exec ${container_name} cat /workspace/.claude-progress 2>/dev/null
2. Parse the output for three marker types:
   - @@PHASE("name") — a phase transition. Report as: **Phase: name**
   - @@UPDATE("detail") — a progress update. Report as a bullet point under the current phase.
   - @@ARTIFACT("type: description") — a concrete output. Collect these for the completion summary.
3. Relay only NEW lines you have not already reported. Skip duplicates.
4. Also check for completion by running:
   docker exec ${container_name} cat /workspace/.claude-done 2>/dev/null
   If this command succeeds, Claude is done. The file contains the exit code.
5. On completion, report:
   - Exit code (0 = success)
   - Phase history (list of phases traversed)
   - All artifacts produced (commits, PRs, test results)
   - Brief summary of the work done
   Then ask the user: "Keep or clean up this container?"

Error handling:
- If a command fails, retry up to 3 consecutive times before reporting a problem.
- A single successful poll resets the failure counter.

For cleanup, run: docker stop ${container_name} && docker rm ${container_name}
MONITOR
}

cmd_run() {
  local repo="" prompt="" branch="" name="" create_pr="false"
  local -a issues=()
  local -a prs=()
  local -a extra_domains=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -r|--repo) repo="${2:?--repo requires a value}"; shift 2 ;;
      -p|--prompt) prompt="${2:?--prompt requires a value}"; shift 2 ;;
      -i|--issue) issues+=("${2:?--issue requires a value}"); shift 2 ;;
      --pr) prs+=("${2:?--pr requires a value}"); shift 2 ;;
      -b|--branch) branch="${2:?--branch requires a value}"; shift 2 ;;
      --name) name="${2:?--name requires a value}"; shift 2 ;;
      --create-pr) create_pr="true"; shift ;;
      --allow-domain) extra_domains+=("${2:?--allow-domain requires a value}"); shift 2 ;;
      -*) die "Unknown flag: $1" ;;
      *) die "Unexpected argument: $1" ;;
    esac
  done

  [[ -n "$repo" ]] || die "--repo is required"

  # Build target list
  local -a target_types=()
  local -a target_values=()

  if [[ -n "$prompt" ]]; then
    target_types+=("prompt")
    target_values+=("$prompt")
  fi
  for i in "${issues[@]}"; do
    target_types+=("issue")
    target_values+=("$i")
  done
  for p in "${prs[@]}"; do
    target_types+=("pr")
    target_values+=("$p")
  done

  [[ ${#target_types[@]} -gt 0 ]] || die "Provide at least one of --prompt, --issue, or --pr"

  # Validate single-container flags
  if [[ ${#target_types[@]} -gt 1 && (-n "$branch" || -n "$name") ]]; then
    die "--branch and --name can only be used with a single target"
  fi

  load_config
  ensure_image

  local extra_domains_str=""
  if [[ ${#extra_domains[@]} -gt 0 ]]; then
    extra_domains_str=$(IFS=,; echo "${extra_domains[*]}")
  fi

  echo "Spawning ${#target_types[@]} container$([ ${#target_types[@]} -gt 1 ] && echo s)..."

  local -a spawned_names=()
  local -a spawned_repos=()

  for idx in "${!target_types[@]}"; do
    local ttype="${target_types[$idx]}"
    local tvalue="${target_values[$idx]}"
    local t_prompt="" t_issue="" t_pr=""
    local label=""

    case "$ttype" in
      prompt) t_prompt="$tvalue"; label="prompt" ;;
      issue)  t_issue="$tvalue"; label="issue #$tvalue" ;;
      pr)     t_pr="$tvalue"; label="PR #$tvalue" ;;
    esac

    local result
    if result=$(spawn_container "$repo" "$t_prompt" "$t_issue" "$t_pr" "$create_pr" "$branch" "$name" "$extra_domains_str"); then
      local container_name repo_out branch_out
      IFS=$'\t' read -r container_name repo_out branch_out <<< "$result"
      spawned_names+=("$container_name")
      spawned_repos+=("$repo_out")
      echo "  [ok] $container_name ($label)"
    else
      echo "  [fail] $label: container failed to start"
    fi
  done

  if [[ ${#spawned_names[@]} -eq 0 ]]; then
    die "All containers failed to start"
  fi

  # Print monitoring hints
  echo ""
  echo "Containers are running. Monitor subagents will report milestones."
  echo "You can also check manually:"
  for i in "${!spawned_names[@]}"; do
    echo "  progress: docker exec ${spawned_names[$i]} cat /workspace/.claude-progress"
    echo "  done:     docker exec ${spawned_names[$i]} cat /workspace/.claude-done"
    echo "  shell:    docker exec -it ${spawned_names[$i]} bash"
  done

  # Print subagent launch instructions
  echo ""
  echo "--- MONITOR SUBAGENT INSTRUCTIONS ---"
  for i in "${!spawned_names[@]}"; do
    local monitor_prompt
    monitor_prompt=$(build_monitor_prompt "${spawned_names[$i]}" "${spawned_repos[$i]}")
    jq -nc --arg name "${spawned_names[$i]}" --arg prompt "$monitor_prompt" \
      '{containerName: $name, prompt: $prompt}'
  done
}

cmd_build() {
  load_config
  local tag="$CONFIG_IMAGE"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tag) tag="${2:?--tag requires a value}"; shift 2 ;;
      -*) die "Unknown flag: $1" ;;
      *) die "Unexpected argument: $1" ;;
    esac
  done

  local current_hash
  current_hash=$(docker_dir_hash)
  echo "Building image $tag..."
  docker build -t "$tag" --label "claude-sandbox.build-hash=$current_hash" "$SCRIPT_DIR/docker"
  echo "Image $tag built successfully."
}

# --- Main ---

usage() {
  cat <<'EOF'
Usage: claude-sandbox <command> [options]

Commands:
  run         Start containers with monitor subagent instructions
  build       Build the Docker image

Container management uses docker directly:
  docker ps -a --filter label=app=claude-sandbox    List containers
  docker exec <name> cat /workspace/.claude-progress View progress
  docker exec -it <name> bash                        Shell into container
  docker stop <name> && docker rm <name>             Clean up

Run 'claude-sandbox <command> --help' for command-specific help.
EOF
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    build)  cmd_build "$@" ;;
    run)    cmd_run "$@" ;;
    -h|--help|help|"") usage ;;
    *)      die "Unknown command: $cmd. Run 'claude-sandbox --help' for usage." ;;
  esac
}

main "$@"
